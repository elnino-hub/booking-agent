# ── Google Calendar ────────────────────────────────────────────────
# Path to your OAuth client credentials file (download from Google Cloud Console)
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# For cloud deployment (Railway / Render): base64-encoded token.json
# Run `python execution/auth_setup.py` locally to generate this value.
# GOOGLE_TOKEN_B64=

# ── API Server ────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────
DB_PATH=history.db

# ── n8n (only needed for running tests) ───────────────────────────
# N8N_BASE_URL=https://your-n8n-instance.com
# N8N_API_KEY=your-n8n-api-key
# N8N_WORKFLOW_ID=your-workflow-id
